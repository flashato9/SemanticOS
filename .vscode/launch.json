{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug Pytest (Current File)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-s", "${file}"],
      "console": "integratedTerminal"
    },
    {
      "name": "Attach to LangGraph",
      "type": "debugpy",
      "request": "attach",
      "justMyCode": false,
      "connect": {
        "host": "127.0.0.1",
        "port": 5679
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/deps/SemanticOS"
        }
      ]
    }
  ]
}
